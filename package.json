{
  "name": "@isdisposable/js",
  "version": "1.0.2",
  "description": "Detect disposable and temporary email addresses. Open source, zero dependencies, 160k+ domains.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build-domains": "tsx scripts/build-domains.ts",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "disposable-email",
    "temp-email",
    "email-validation",
    "email-verification",
    "spam-prevention",
    "signup-protection",
    "burner-email",
    "throwaway-email",
    "email-blocklist",
    "saas-security"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/isdisposable/js"
  },
  "homepage": "https://isdisposable.com",
  "devDependencies": {
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3"
  }
}
